# Server Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# Server Configuration
# ============================================================
PORT=5050
NODE_ENV=development

# ============================================================
# MongoDB Connection
# ============================================================
# Local: mongodb://localhost:27017/prodigy_auth
# Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/prodigy_auth
MONGO_URI=mongodb://localhost:27017/prodigy_auth

# ============================================================
# JWT Secrets (use strong, random strings in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================
JWT_ACCESS_SECRET=your_super_secret_access_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production

# ============================================================
# JWT Expiry
# ============================================================
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ============================================================
# Client Origin (CORS)
# ============================================================
# Development: http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
